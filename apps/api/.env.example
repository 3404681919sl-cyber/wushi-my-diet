# 吾食（Wushi）后端环境变量示例
# 复制为 .env 后按需修改：cp .env.example .env

# ---------- 数据库 ----------
# 生产目标：PostgreSQL + asyncpg
# DATABASE_URL=postgresql+asyncpg://wushi:wushi@localhost:5432/wushi
# 本地无 Docker / PostgreSQL 时，可用 SQLite 验证（JSONB 自动编译为 JSON）：
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# ---------- Redis（可选，F4，本期未强制）----------
# 留空表示不使用
REDIS_URL=

# ---------- JWT ----------
# 生产务必替换为强随机密钥（如 openssl rand -hex 32）
JWT_SECRET=change-me-in-production-please-replace
JWT_ALGORITHM=HS256
# Access Token 有效期（分钟），默认 7 天
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---------- DeepSeek（T3 食谱生成，本期预留）----------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# ---------- 微信开放平台（T1 预留 wechat-login）----------
WECHAT_APPID=
WECHAT_SECRET=

# ---------- CORS ----------
# 逗号分隔的前端来源；开发可填 * ，生产请明确来源
CORS_ORIGINS=*
