    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@babel/runtime": "^7.24.0",
    "@tarojs/cli": "3.6.40",
    "@tarojs/plugin-framework-vue3": "3.6.40",
    "@tarojs/plugin-platform-weapp": "3.6.40",
