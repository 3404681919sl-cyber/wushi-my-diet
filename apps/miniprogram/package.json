    "@tarojs/taro": "^3.6.0",
    "echarts": "^5.5.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "@wushi/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
